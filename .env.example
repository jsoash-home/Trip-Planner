# Copy this file to `.env` and fill in real values.
# Never commit `.env` — it's in .gitignore.

# Random secret used to sign session cookies. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_me_with_a_long_random_string

# Google OAuth credentials from https://console.cloud.google.com/apis/credentials
# Create an "OAuth client ID" of type "Web application" with these redirect URIs:
#   http://localhost:5002/login/google/authorized
#   https://your-deployed-domain.example/login/google/authorized   (if you deploy)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional. If set, the app uses this database instead of local SQLite.
# Postgres URLs from Railway/Render arrive as "postgres://..." — the app
# auto-rewrites them to "postgresql://..." for SQLAlchemy.
# DATABASE_URL=

# Mapbox public access token (pk.*). Used by the map view feature.
# Get one at https://account.mapbox.com — restrict by referrer domain
# in the dashboard so a leaked token can't be abused.
MAPBOX_TOKEN=
